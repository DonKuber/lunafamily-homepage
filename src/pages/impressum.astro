---
import Base from '../layouts/Base.astro';
---

<Base
  title="Impressum – LunaFamily"
  description="Impressum der LunaFamily GmbH gemäß § 18 MStV."
>

<!-- Nav -->
<nav class="sticky top-0 z-50 bg-background/95 backdrop-blur border-b border-border">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 h-16 flex items-center justify-between">
    <a href="/" class="font-bold text-lg text-foreground hover:text-primary transition-colors">
      LunaFamily
    </a>
    <a href="https://app.lunafamily.online/login" class="text-sm text-muted-foreground hover:text-foreground transition-colors" rel="noopener">
      Anmelden
    </a>
  </div>
</nav>

<!-- Content -->
<main class="max-w-3xl mx-auto px-4 sm:px-6 py-14 min-h-[70vh]">
  <a href="/" class="inline-flex items-center gap-1.5 text-sm text-muted-foreground hover:text-foreground transition-colors mb-8">
    <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <path d="m15 18-6-6 6-6"/>
    </svg>
    Zurück zur Startseite
  </a>

  <h1 class="text-3xl sm:text-4xl font-bold text-foreground mb-2">Impressum</h1>
  <p class="text-muted-foreground mb-10">Angaben gemäß § 18 MStV</p>

  <div id="lf-legal-content" class="prose prose-stone max-w-none">
    <!-- Wird vom ControlPanel-Webhook befüllt -->
    <div class="rounded-xl border border-border bg-card p-6 text-sm text-muted-foreground">
      Der Inhalt dieser Seite wird automatisch vom ControlPanel aktualisiert.
    </div>
  </div>
</main>

<!-- Footer -->
<footer class="border-t border-border py-8 px-4 sm:px-6">
  <div class="max-w-6xl mx-auto flex flex-col sm:flex-row items-center justify-between gap-4">
    <a href="/" class="font-semibold text-foreground hover:text-primary transition-colors">LunaFamily</a>
    <nav class="flex flex-wrap items-center justify-center gap-x-6 gap-y-2" aria-label="Footer-Navigation">
      <a href="/impressum"   class="text-sm text-primary font-medium">Impressum</a>
      <a href="/datenschutz" class="text-sm text-muted-foreground hover:text-foreground transition-colors">Datenschutz</a>
      <a href="https://app.lunafamily.online/login"    class="text-sm text-muted-foreground hover:text-foreground transition-colors" rel="noopener">Anmelden</a>
      <a href="https://app.lunafamily.online/register" class="text-sm text-muted-foreground hover:text-foreground transition-colors" rel="noopener">Registrieren</a>
    </nav>
    <p class="text-sm text-muted-foreground">&copy; {new Date().getFullYear()} LunaFamily</p>
  </div>
</footer>

</Base>
