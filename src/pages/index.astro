---
import Base from '../layouts/Base.astro';

// ─── Icon SVG path strings (inner content only, Lucide-compatible) ─────────────
const IC = {
  heart:       `<path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/>`,
  shield:      `<path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>`,
  lock:        `<rect width="18" height="11" x="3" y="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/>`,
  smartphone:  `<rect width="14" height="20" x="5" y="2" rx="2" ry="2"/><path d="M12 18h.01"/>`,
  globe:       `<circle cx="12" cy="12" r="10"/><line x1="2" y1="12" x2="22" y2="12"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/>`,
  arrowRight:  `<path d="M5 12h14"/><path d="m12 5 7 7-7 7"/>`,
  chevronRight:`<path d="m9 18 6-6-6-6"/>`,
  flask:       `<path d="M10 2v7.527a2 2 0 0 1-.211.896L4.72 20.55a1 1 0 0 0 .9 1.45h12.76a1 1 0 0 0 .9-1.45l-5.069-10.127A2 2 0 0 1 14 9.527V2"/><path d="M8.5 2h7"/>`,
  sparkles:    `<path d="m12 3-1.912 5.813a2 2 0 0 1-1.275 1.275L3 12l5.813 1.912a2 2 0 0 1 1.275 1.275L12 21l1.912-5.813a2 2 0 0 1 1.275-1.275L21 12l-5.813-1.912a2 2 0 0 1-1.275-1.275L12 3Z"/><path d="M5 3v4"/><path d="M19 17v4"/><path d="M3 5h4"/><path d="M17 19h4"/>`,
  checkCheck:  `<path d="M18 6 7 17l-5-5"/><path d="m22 10-7.5 7.5L13 16"/>`,
  star:        `<polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/>`,
  construction:`<rect x="2" y="6" width="20" height="8" rx="1"/><path d="M17 14v7"/><path d="M7 14v7"/><path d="M17 3v3"/><path d="M7 3v3"/><path d="M10 14 2.3 6.3"/><path d="m14 6 7.7 7.7"/><path d="m8 6 8 8"/>`,
  zap:         `<polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/>`,
  clock:       `<circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/>`,
  users:       `<path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/>`,
  // category icons
  calendar:    `<rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/>`,
  checkCircle: `<circle cx="12" cy="12" r="10"/><path d="m9 12 2 2 4-4"/>`,
  fileText:    `<path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/>`,
  utensils:    `<path d="M3 2v7c0 1.1.9 2 2 2h4a2 2 0 0 0 2-2V2"/><path d="M7 2v20"/><path d="M21 15V2a5 5 0 0 0-5 5v6c0 1.1.9 2 2 2h3v7"/>`,
  home:        `<path d="m3 9 9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/>`,
  wallet:      `<path d="M21 12V7H5a2 2 0 0 1 0-4h14v4"/><path d="M3 5v14a2 2 0 0 0 2 2h16v-5"/><path d="M18 12a2 2 0 0 0 0 4h4v-4Z"/>`,
  mail:        `<rect width="20" height="16" x="2" y="4" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/>`,
  graduationCap:`<path d="M22 10v6M2 10l10-5 10 5-10 5z"/><path d="M6 12v5c3 3 9 3 12 0v-5"/>`,
  barChart:    `<path d="M3 3v18h18"/><path d="M18 17V9"/><path d="M13 17V5"/><path d="M8 17v-3"/>`,
};

interface Category {
  icon: string;
  gradient: string;
  status: 'available' | 'partial' | 'coming';
  title: string;
  subtitle: string;
  features: string[];
}

const CATEGORIES: Category[] = [
  { icon: IC.calendar,     gradient: 'from-blue-500 to-cyan-500',    status: 'available', title: 'Kalender & Planung',        subtitle: 'Nie wieder einen Termin verpassen',         features: ['Familien-Kalender', 'Wiederkehrende Termine', 'Event-Planung & Abstimmungen', 'Erinnerungen & Push-Benachrichtigungen'] },
  { icon: IC.checkCircle,  gradient: 'from-green-500 to-emerald-500',status: 'available', title: 'Aufgaben & Todos',            subtitle: 'Gemeinsam mehr erledigen',                   features: ['Aufgabenlisten für alle', 'Subtasks & Prioritäten', 'Kategorien & Tags', 'Fälligkeitsdaten & Zuweisung'] },
  { icon: IC.fileText,     gradient: 'from-orange-500 to-amber-500', status: 'available', title: 'Dokumente (Paperless)',       subtitle: 'Papierkram endlich digital',                 features: ['Rechnungen & Verträge', 'Automatische OCR-Erkennung', 'Intelligente Kategorisierung', 'Schnelle Volltextsuche'] },
  { icon: IC.utensils,     gradient: 'from-rose-500 to-pink-500',    status: 'available', title: 'Küche & Ernährung',           subtitle: 'Kochen wird wieder Freude',                  features: ['Rezeptsammlung', 'Mahlzeitenplanung', 'Auto-Einkaufslisten', 'Kalorientracking'] },
  { icon: IC.users,        gradient: 'from-violet-500 to-purple-500',status: 'available', title: 'Familie & Kontakte',          subtitle: 'Alle Verbindungen an einem Ort',             features: ['Familienmitglieder verwalten', 'Stammbaum visualisieren', 'Kontaktbuch mit CRM', 'Firmen & Verträge'] },
  { icon: IC.home,         gradient: 'from-teal-500 to-green-500',   status: 'available', title: 'Haushalt',                    subtitle: 'Der Haushalt läuft sich fast von selbst',    features: ['Haushaltsaufgaben & Gamification', 'Inventar verwalten', 'Bedienungsanleitungen', 'Haushaltsplaner'] },
  { icon: IC.wallet,       gradient: 'from-yellow-500 to-orange-500',status: 'partial',   title: 'Finanzen',                    subtitle: 'Volle Kontrolle über das Familienbudget',    features: ['Open Banking (GoCardless)', 'Ausgaben & Budgets', 'Kredite & Investments', 'Steuerübersicht'] },
  { icon: IC.mail,         gradient: 'from-sky-500 to-blue-500',     status: 'partial',   title: 'Kommunikation',               subtitle: 'Immer verbunden, egal wo',                   features: ['Familien-Nachrichten', 'Integrierter E-Mail-Client', 'Ankündigungen', 'Anrufverlauf'] },
  { icon: IC.graduationCap,gradient: 'from-indigo-500 to-violet-500',status: 'partial',   title: 'Schule & Bildung',            subtitle: 'Lernfortschritt im Blick',                   features: ['Schultermine & Hausaufgaben', 'Noten & Zeugnisse', 'Lernpläne', 'Studienmanagement'] },
  { icon: IC.sparkles,     gradient: 'from-pink-500 to-rose-500',    status: 'coming',    title: 'KI-Assistent',                subtitle: 'Intelligente Unterstützung im Alltag',       features: ['Automatische Kategorisierung', 'Smarte Vorschläge', 'E-Mail-Review & Zusammenfassungen', 'Multi-Provider KI'] },
  { icon: IC.smartphone,   gradient: 'from-slate-500 to-gray-600',   status: 'coming',    title: 'Mobile App (Offline)',         subtitle: 'Immer dabei, auch ohne Internet',             features: ['iOS & Android App', 'Offline-First Architektur', 'Automatische Synchronisation', 'Biometrische Absicherung'] },
  { icon: IC.barChart,     gradient: 'from-cyan-500 to-teal-500',    status: 'partial',   title: 'Statistiken & Insights',      subtitle: 'Daten, die wirklich helfen',                 features: ['Familien-Dashboard', 'Aktivitätsberichte', 'Ausgaben-Trends', 'Produktivitäts-Insights'] },
];

const WHY_CARDS = [
  { icon: IC.shield, color: 'text-green-500', title: 'Deine Daten. Deine Regeln.',     text: 'Keine Werbeanzeigen, kein Tracking, kein Datenverkauf. Was in deiner Familie passiert, bleibt in deiner Familie.' },
  { icon: IC.heart,  color: 'text-rose-500',  title: 'Entspannt durch den Alltag',     text: 'Weniger Stress, weniger Chaos — mehr Zeit für die Momente, die wirklich zählen. LunaFamily übernimmt die Koordination.' },
  { icon: IC.users,  color: 'text-primary',   title: 'Für die ganze Familie',          text: 'Jedes Familienmitglied hat sein eigenes Profil. Geteilte Inhalte, private Bereiche — du entscheidest.' },
  { icon: IC.lock,   color: 'text-blue-500',  title: 'Nur ihr. Kein anderer.',         text: 'Deine Familie bekommt eine eigene, komplett isolierte Umgebung. Kein anderer Nutzer kann eure Daten sehen — technisch unmöglich.' },
  { icon: IC.zap,    color: 'text-amber-500', title: 'Einfach. Direkt. Sofort.',       text: 'Kein Einrichtungs-Marathon. In 2 Minuten registriert und direkt loslegen — für dich, deinen Partner und die Kinder.' },
  { icon: IC.flask,  color: 'text-primary',   title: 'Du gestaltest mit',              text: 'Als Beta-Nutzer hast du direkten Einfluss. Wir bauen, was echte Familien wirklich brauchen.' },
];

const BETA_CARDS = [
  { icon: IC.flask,       color: 'text-primary',   title: 'Aktive Entwicklung',                    text: 'LunaFamily wird täglich weiterentwickelt. Jede Woche kommen neue Features und Verbesserungen.' },
  { icon: IC.star,        color: 'text-amber-500', title: 'Dein Feedback formt das Produkt',       text: 'Als Early Adopter hast du direkten Einfluss. Was dir fehlt, bauen wir als nächstes.' },
  { icon: IC.heart,       color: 'text-rose-500',  title: 'Kostenlos während der Beta',            text: 'Alle Features sind in der Beta-Phase vollständig kostenlos nutzbar. Keine Kreditkarte nötig.' },
  { icon: IC.shield,      color: 'text-green-500', title: 'Sicherheit ist keine Beta-Funktion',    text: 'DSGVO, Verschlüsselung, Malware-Schutz — Sicherheit ist von Anfang an eingebaut, nicht nachträglich.' },
  { icon: IC.clock,       color: 'text-blue-500',  title: 'Module rollen schrittweise aus',        text: 'Nicht alle Module sind sofort verfügbar. Wir schalten sie frei, sobald sie stabil und getestet sind.' },
  { icon: IC.zap,         color: 'text-primary',   title: 'Schnelle Bug-Fixes',                    text: 'Wenn etwas nicht stimmt, beheben wir es schnell. Transparente Kommunikation ist uns wichtig.' },
];

const ROADMAP_DONE = [
  'Kalender & Termine', 'Aufgaben & Todos mit Subtasks', 'Dokumente (Paperless-ngx)',
  'Rezepte, Einkauf & Mahlzeiten', 'Familienmitglieder & Kontakte', 'Haushalt & Inventar',
  'Familien-Nachrichten', 'Push-Benachrichtigungen', 'Tagebuch & Erfolgsjournal',
];
const ROADMAP_WIP = [
  'Open Banking (GoCardless)', 'E-Mail-Client Integration', 'Schul- & Studienmanagement',
  'Crypto-Portfolio', 'Statistiken & Reports', 'Event-Planung & Abstimmungen',
];
const ROADMAP_PLANNED = [
  'Mobile App (iOS & Android)', 'KI-Assistent (Multi-Provider)', 'Familien-Foto-Galerie',
  'Mehrsprachigkeit (EN, FR)', 'Apple/Google Calendar Sync', 'Offline-First Sync Engine',
];

const STATUS = {
  available: { label: 'Verfügbar',      cls: 'bg-green-100 text-green-700 border-green-200' },
  partial:   { label: 'In Entwicklung', cls: 'bg-amber-100 text-amber-700 border-amber-200' },
  coming:    { label: 'Demnächst',      cls: 'bg-slate-100 text-slate-600 border-slate-200' },
};
---

<Base
  title="LunaFamily – Das digitale Zuhause für deine Familie"
  description="Kalender, Aufgaben, Dokumente, Finanzen, Rezepte und vieles mehr — alles an einem Ort, für die ganze Familie. Sicher. In Deutschland gehostet. DSGVO-konform."
>

<style is:global>
  @keyframes lf-float1 { 0%,100%{transform:translate(0,0)} 50%{transform:translate(40px,-50px)} }
  @keyframes lf-float2 { 0%,100%{transform:translate(0,0)} 50%{transform:translate(-30px,40px)} }
  @keyframes lf-float3 { 0%,100%{transform:translate(-50%,-50%)} 50%{transform:translate(-50%,calc(-50% - 25px))} }
  @keyframes lf-fadein  { from{opacity:0;transform:translateY(2.5rem)} to{opacity:1;transform:translateY(0)} }

  .lf-hero { animation: lf-fadein 1s ease forwards; }

  .lf-animate {
    opacity: 0;
    transform: translateY(2rem);
    transition: opacity .7s ease, transform .7s ease;
  }
  .lf-animate.lf-visible {
    opacity: 1;
    transform: translateY(0);
  }

  #lf-nav.lf-scrolled {
    background-color: rgba(249,245,239,.95);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border-bottom: 1px solid #e8e0d5;
    box-shadow: 0 1px 3px rgba(0,0,0,.05);
  }
</style>

<!-- ─── Navbar ─────────────────────────────────────────────────────────────── -->
<nav id="lf-nav" class="fixed top-0 left-0 right-0 z-50 transition-all duration-300">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 h-16 flex items-center justify-between">
    <div class="flex items-center gap-2">
      <div class="w-8 h-8 rounded-lg flex items-center justify-center flex-shrink-0"
           style="background:linear-gradient(135deg,#c4a265,#c09556);box-shadow:0 4px 12px rgba(196,162,101,.3)">
        <svg class="w-4 h-4 text-white" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <Fragment set:html={IC.heart} />
        </svg>
      </div>
      <span class="font-bold text-lg text-foreground">LunaFamily</span>
      <span class="ml-1 px-2 py-0.5 text-xs font-semibold bg-amber-100 text-amber-700 rounded-full border border-amber-200">BETA</span>
    </div>
    <div class="flex items-center gap-1.5 sm:gap-3">
      <a href="https://app.lunafamily.online/login" class="text-xs sm:text-sm text-muted-foreground hover:text-foreground transition-colors" rel="noopener">
        Anmelden
      </a>
      <a href="https://app.lunafamily.online/register"
         class="bg-primary hover:bg-primary/90 text-primary-foreground text-xs sm:text-sm font-semibold px-3 sm:px-4 py-2 rounded-lg transition-colors"
         style="box-shadow:0 4px 12px rgba(196,162,101,.2)" rel="noopener">
        Registrieren
      </a>
    </div>
  </div>
</nav>

<!-- ─── Beta Banner ───────────────────────────────────────────────────────── -->
<div class="bg-amber-50 border-b border-amber-200 py-2.5 px-4 text-center mt-16">
  <p class="text-sm text-amber-800 flex items-center justify-center gap-2 flex-wrap">
    <svg class="w-4 h-4 flex-shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <Fragment set:html={IC.flask} />
    </svg>
    <span>
      <strong>Öffentliche Beta:</strong> LunaFamily wird aktiv weiterentwickelt. Module werden schrittweise freigeschaltet.
    </span>
    <a href="mailto:feedback@lunafamily.de" class="underline font-medium hover:text-amber-900 transition-colors">
      Feedback geben →
    </a>
  </p>
</div>

<!-- ─── Hero ──────────────────────────────────────────────────────────────── -->
<section class="relative min-h-[92vh] flex items-center justify-center overflow-hidden" aria-labelledby="hero-heading">
  <div class="absolute inset-0 -z-10">
    <div class="absolute inset-0 bg-background"></div>
    <div class="absolute top-1/3 -left-40 w-[600px] h-[600px] rounded-full opacity-[0.18]"
         style="background:radial-gradient(circle,#c4a265 0%,transparent 65%);animation:lf-float1 9s ease-in-out infinite" aria-hidden="true"></div>
    <div class="absolute bottom-1/4 -right-40 w-[500px] h-[500px] rounded-full opacity-[0.14]"
         style="background:radial-gradient(circle,#d4b378 0%,transparent 65%);animation:lf-float2 12s ease-in-out infinite" aria-hidden="true"></div>
    <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[350px] h-[350px] rounded-full opacity-[0.10]"
         style="background:radial-gradient(circle,#8fae6b 0%,transparent 65%);animation:lf-float3 15s ease-in-out infinite" aria-hidden="true"></div>
  </div>

  <div class="lf-hero max-w-4xl mx-auto px-4 sm:px-6 text-center">
    <div class="inline-flex items-center gap-2 px-4 py-2 rounded-full border text-sm font-medium mb-8"
         style="background:rgba(196,162,101,.1);border-color:rgba(196,162,101,.3);color:#c4a265">
      <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <Fragment set:html={IC.flask} />
      </svg>
      Early Access Beta — Jetzt kostenlos mitmachen
    </div>

    <h1 id="hero-heading" class="text-4xl sm:text-5xl lg:text-7xl font-bold text-foreground mb-6 leading-[1.1] tracking-tight">
      Das digitale{' '}
      <span style="background:linear-gradient(90deg,#c4a265,#c09556,#c4a265);-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text">
        Zuhause
      </span>{' '}
      für deine Familie.
    </h1>

    <p class="text-lg sm:text-xl text-muted-foreground mb-12 max-w-2xl mx-auto leading-relaxed">
      Kalender, Aufgaben, Dokumente, Finanzen, Rezepte und vieles mehr — alles an einem Ort, für die ganze Familie. Sicher. In Deutschland gehostet. DSGVO-konform.
    </p>

    <div class="flex flex-col sm:flex-row gap-4 justify-center items-center mb-14">
      <a href="https://app.lunafamily.online/register"
         class="w-full sm:w-auto inline-flex items-center justify-center gap-2 bg-primary hover:bg-primary/90 text-primary-foreground font-semibold px-10 py-4 text-base rounded-xl transition-colors"
         style="box-shadow:0 20px 40px rgba(196,162,101,.25)" rel="noopener">
        Jetzt kostenlos registrieren
        <svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <Fragment set:html={IC.arrowRight} />
        </svg>
      </a>
      <a href="https://app.lunafamily.online/login"
         class="w-full sm:w-auto inline-flex items-center justify-center border border-border bg-card text-foreground font-semibold px-10 py-4 text-base rounded-xl hover:bg-muted transition-colors"
         rel="noopener">
        Bereits registriert? Anmelden
      </a>
    </div>

    <div class="flex flex-wrap items-center justify-center gap-6 text-sm text-muted-foreground">
      <span class="flex items-center gap-1.5">
        <svg class="w-4 h-4 text-green-500" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><Fragment set:html={IC.shield} /></svg>
        DSGVO-konform
      </span>
      <span class="flex items-center gap-1.5">
        <svg class="w-4 h-4 text-blue-500" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><Fragment set:html={IC.lock} /></svg>
        Server in Deutschland
      </span>
      <span class="flex items-center gap-1.5">
        <svg class="w-4 h-4 text-rose-500" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><Fragment set:html={IC.heart} /></svg>
        Kostenlos in der Beta
      </span>
      <span class="flex items-center gap-1.5" style="color:#7d7060">
        <svg class="w-4 h-4 text-primary" viewBox="0 0 24 24" fill="none" stroke="#c4a265" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><Fragment set:html={IC.smartphone} /></svg>
        Web & Mobile
      </span>
      <span class="flex items-center gap-1.5">
        <svg class="w-4 h-4 text-sky-500" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><Fragment set:html={IC.globe} /></svg>
        Multi-Tenant
      </span>
    </div>
  </div>
</section>

<!-- ─── Features ─────────────────────────────────────────────────────────── -->
<section class="py-24 px-4 sm:px-6 bg-muted/20" aria-labelledby="features-heading">
  <div class="max-w-6xl mx-auto">
    <div class="lf-animate text-center mb-16">
      <div class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full border text-sm font-medium mb-5"
           style="background:rgba(196,162,101,.1);border-color:rgba(196,162,101,.3);color:#c4a265">
        <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <Fragment set:html={IC.sparkles} />
        </svg>
        12 Module, ein System
      </div>
      <h2 id="features-heading" class="text-3xl sm:text-4xl lg:text-5xl font-bold text-foreground mb-5">
        Alles, was deine Familie braucht
      </h2>
      <p class="text-muted-foreground text-lg max-w-2xl mx-auto leading-relaxed">
        LunaFamily vereint alle wichtigen Funktionen für den Familienalltag in einer einzigen, sicheren Plattform — statt 12 verschiedene Apps.
      </p>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5">
      {CATEGORIES.map((cat, i) => {
        const st = STATUS[cat.status];
        const isComingSoon = cat.status === 'coming';
        return (
          <div class="lf-animate" style={`transition-delay:${Math.min(i * 50, 300)}ms`}>
            <div class={`h-full border border-border bg-card rounded-2xl p-6 transition-all duration-300 ${isComingSoon ? 'opacity-75' : 'hover:shadow-md hover:-translate-y-0.5'}`}>
              <div class="flex items-start justify-between mb-4">
                <div class={`p-3 rounded-xl bg-gradient-to-br ${cat.gradient} text-white shadow-sm`}>
                  <svg class="w-7 h-7" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                    <Fragment set:html={cat.icon} />
                  </svg>
                </div>
                <span class={`px-2.5 py-1 rounded-full text-xs font-semibold border ${st.cls}`}>
                  {st.label}
                </span>
              </div>
              <h3 class="font-bold text-foreground text-lg mb-1">{cat.title}</h3>
              <p class="text-muted-foreground text-sm mb-4 leading-relaxed">{cat.subtitle}</p>
              <ul class="space-y-2">
