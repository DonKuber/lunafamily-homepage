<script>
  // Navbar scroll effect
  const nav = document.getElementById('lf-nav');
  if (nav) {
    window.addEventListener('scroll', () => {
      nav.classList.toggle('lf-scrolled', window.scrollY > 20);
    }, { passive: true });
  }

  // Scroll-triggered fade-in animations
  const io = new IntersectionObserver(
    (entries) => entries.forEach(e => {
      if (e.isIntersecting) {
        e.target.classList.add('lf-visible');
        io.unobserve(e.target);
      }
    }),
    { threshold: 0.08 }
  );
  document.querySelectorAll('.lf-animate').forEach(el => io.observe(el));
</script>

